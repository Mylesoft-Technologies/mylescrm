# ============================================================
# MylesCRM Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Convex ──────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOY_KEY=

# ── WorkOS AuthKit ──────────────────────────────────────────
WORKOS_API_KEY=sk_live_xxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxx
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
WORKOS_COOKIE_PASSWORD=your-32-char-or-more-secret-cookie-password

# ── Resend (Email) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=crm@yourdomain.com
RESEND_FROM_NAME=MylesCRM

# ── Stripe (Payments) ───────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_STARTER_ANNUAL_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_GROWTH_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_GROWTH_ANNUAL_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_xxxxxxxxxxxx

# ── M-Pesa Daraja (Mobile Money) ────────────────────────────
MPESA_CONSUMER_KEY=xxxxxxxxxxxx
MPESA_CONSUMER_SECRET=xxxxxxxxxxxx
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=xxxxxxxxxxxx
MPESA_ENVIRONMENT=sandbox
# sandbox: https://sandbox.safaricom.co.ke
# production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=https://yourdomain.com/api/webhooks/daraja

# ── OpenRouter AI ───────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_FAST_MODEL=openai/gpt-4o-mini

# ── Cal.com (Booking) ───────────────────────────────────────
CALCOM_API_KEY=cal_live_xxxxxxxxxxxx
CALCOM_API_URL=https://api.cal.com/v1
NEXT_PUBLIC_CALCOM_USERNAME=your-calcom-username

# ── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MylesCRM
NEXT_PUBLIC_APP_VERSION=1.0.0
APP_SECRET=your-app-secret-key-min-32-chars

# ── Feature Flags ───────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_MPESA=true
NEXT_PUBLIC_ENABLE_CALCOM=true
